#-------------------Permutation Spearman function (NO warnings, NO packages)-------------------
perm_spearman_test <- function(x, y, R=10000) {
  obs_cor <- cor(x, y, method = "spearman")
  null_dist <- replicate(R, cor(sample(x), y, method = "spearman"))
  p_val <- mean(abs(null_dist) >= abs(obs_cor))
  list(Observed = obs_cor, p.value = p_val)
}

# data.frame for result
results <- data.frame(
  variable = character(),
  spearman_corr = numeric(),
  s_p_value = numeric(),
  stringsAsFactors = FALSE
)

# variables for analysis
target_vars <- c("antioxidant2", "antioxidant3", "antioxidant4")

# main loop for antioxidant1 vs others
for (var in target_vars) {
  perm_spearman <- perm_spearman_test(
    x = data$antioxidant1,
    y = data[[var]]
  )
  
  results <- rbind(results, data.frame(
    variable = var,
    spearman_corr = perm_spearman$Observed,
    s_p_value = perm_spearman$p.value
  ))
}

